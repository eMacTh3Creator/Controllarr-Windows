<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="CategoriesViewTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ Left panel: Category list ══════════════════════ -->
            <DockPanel Grid.Column="0"
                       Background="{StaticResource SurfaceBrush}"
                       LastChildFill="True">

                <!-- Header + buttons -->
                <Border DockPanel.Dock="Top" Padding="16,16,16,8">
                    <StackPanel>
                        <TextBlock Text="Categories" Style="{StaticResource SubheaderText}"
                                   Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Add" Style="{StaticResource AccentButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0"/>
                            <Button Content="Remove" Style="{StaticResource DangerButton}"
                                    Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Category list -->
                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         DisplayMemberPath="Name"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="8,0,8,8"/>
            </DockPanel>

            <!-- ══ Right panel: Category editor ═══════════════════ -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,16">
                <StackPanel MaxWidth="560">

                    <!-- Show editor only when a category is selected -->
                    <StackPanel DataContext="{Binding SelectedCategory}">

                        <TextBlock Text="Category Details" Style="{StaticResource HeaderText}"
                                   Margin="0,0,0,20"/>

                        <!-- Name -->
                        <TextBlock Text="Name" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"/>

                        <!-- Save Path -->
                        <TextBlock Text="Save Path" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SavePath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                    Style="{StaticResource SubtleButton}"/>
                        </Grid>

                        <!-- Complete Path -->
                        <TextBlock Text="Complete Path (post-processing destination)" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding CompletePath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0"
                                    Style="{StaticResource SubtleButton}"/>
                        </Grid>

                        <!-- Extract Archives -->
                        <CheckBox Content="Extract archives after download"
                                  IsChecked="{Binding ExtractArchives}"
                                  Margin="0,0,0,16"/>

                        <!-- Blocked Extensions -->
                        <TextBlock Text="Blocked Extensions (comma-separated, e.g. .exe,.bat)" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                        <TextBox Margin="0,0,0,16"/>

                        <!-- Max Ratio -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Max Ratio (override)" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="0"
                                     Text="{Binding MaxRatio, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Max Seed Time (min, override)" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="2"
                                     Text="{Binding MaxSeedingTimeMinutes, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                        </Grid>

                        <!-- Action buttons -->
                        <Separator Margin="0,8,0,16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource AccentButton}"
                                    Content="Save Category"
                                    Margin="0,0,12,0"/>
                            <Button Style="{StaticResource DangerButton}"
                                    Content="Delete Category"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Empty state -->
                    <TextBlock Text="Select a category to edit, or create a new one."
                               HorizontalAlignment="Center"
                               Margin="0,60,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DataTemplate>

</ResourceDictionary>
