<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="HealthViewTemplate">
        <DockPanel>

            <!-- ══ Header ═════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top"
                    Padding="24,16">
                <StackPanel>
                    <TextBlock Text="Health Monitor" Style="{StaticResource HeaderText}"
                               Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource SecondaryText}">
                        <Run Text="Monitoring stalled and unhealthy torrents. "/>
                        <Run Text="{Binding HealthIssues.Count, Mode=OneWay}"/>
                        <Run Text=" active issue(s)"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ══ DataGrid ═══════════════════════════════════════ -->
            <DataGrid ItemsSource="{Binding HealthIssues}"
                      Margin="24,0,24,24">

                <DataGrid.Columns>
                    <!-- Torrent Name -->
                    <DataGridTextColumn Header="Torrent"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        MinWidth="200"/>

                    <!-- Reason -->
                    <DataGridTemplateColumn Header="Reason" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,3"
                                        HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Reason}" Value="NoPeers">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#3B1C1C"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Reason}" Value="MetadataTimeout">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="#3B2D1C"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Reason}" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- First Seen -->
                    <DataGridTextColumn Header="First Seen"
                                        Binding="{Binding FirstSeen, StringFormat='{}{0:MMM dd HH:mm}'}"
                                        Width="120"/>

                    <!-- Last Progress -->
                    <DataGridTextColumn Header="Last Progress"
                                        Binding="{Binding LastProgress, StringFormat='{}{0:P1}'}"
                                        Width="100"/>

                    <!-- Duration -->
                    <DataGridTemplateColumn Header="Duration" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                                    <TextBlock.Text>
                                        <Binding Path="FirstSeen"
                                                 StringFormat="{}stalled"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Actions" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource SubtleButton}"
                                            Content="Clear"
                                            Command="{Binding DataContext.ClearHealthIssueCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding InfoHash}"
                                            Margin="0,0,8,0"/>
                                    <Button Style="{StaticResource SubtleButton}"
                                            Content="Recovery"
                                            Foreground="{StaticResource AccentLightBrush}"
                                            Command="{Binding DataContext.RunRecoveryCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding InfoHash}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DataTemplate>

</ResourceDictionary>
