<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:Controllarr.App.ViewModels">

    <DataTemplate x:Key="TorrentsViewTemplate">
        <DockPanel Margin="0">

            <!-- ══ Toolbar ═════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Action buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- Add Magnet -->
                        <Button Style="{StaticResource AccentButton}"
                                Command="{Binding AddMagnetCommand}"
                                Margin="0,0,8,0"
                                Visibility="{Binding IsAddMagnetOpen, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE948;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Add Magnet" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Add Magnet inline popup -->
                        <Border Background="{StaticResource SurfaceLightBrush}"
                                CornerRadius="6"
                                Padding="4"
                                Margin="0,0,8,0"
                                Visibility="{Binding IsAddMagnetOpen, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding AddMagnetText, UpdateSourceTrigger=PropertyChanged}"
                                         Width="400"
                                         VerticalAlignment="Center"/>
                                <Button Style="{StaticResource AccentButton}"
                                        Content="Add"
                                        Command="{Binding AddMagnetCommand}"
                                        Margin="4,0,0,0"/>
                                <Button Style="{StaticResource SubtleButton}"
                                        Content="Cancel"
                                        Margin="4,0,0,0">
                                    <Button.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SelectTabCommand}"
                                                      CommandParameter="Torrents"/>
                                    </Button.InputBindings>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Add .torrent File -->
                        <Button Command="{Binding AddTorrentFileCommand}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Add File" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Cycle Port -->
                        <Button Command="{Binding CyclePortCommand}"
                                ToolTip="Randomize listen port">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Cycle Port" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Right: Torrent count -->
                    <TextBlock Grid.Column="2"
                               Style="{StaticResource SecondaryText}"
                               VerticalAlignment="Center">
                        <Run Text="{Binding Torrents.Count, Mode=OneWay}"/>
                        <Run Text="torrents"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ══ DataGrid ════════════════════════════════════════ -->
            <DataGrid ItemsSource="{Binding Torrents}"
                      SelectedItem="{Binding SelectedTorrent, Mode=TwoWay}"
                      Margin="0">

                <!-- Context Menu -->
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Pause"
                                  Command="{Binding PauseTorrentCommand}"
                                  CommandParameter="{Binding SelectedTorrent.InfoHash}"/>
                        <MenuItem Header="Resume"
                                  Command="{Binding ResumeTorrentCommand}"
                                  CommandParameter="{Binding SelectedTorrent.InfoHash}"/>
                        <Separator/>
                        <MenuItem Header="Reannounce"
                                  Command="{Binding ReannounceTorrentCommand}"
                                  CommandParameter="{Binding SelectedTorrent.InfoHash}"/>
                        <Separator/>
                        <MenuItem Header="Remove"
                                  Command="{Binding RemoveTorrentCommand}"
                                  CommandParameter="{Binding SelectedTorrent.InfoHash}"/>
                        <MenuItem Header="Remove with Files"
                                  Foreground="{StaticResource ErrorBrush}"
                                  Command="{Binding RemoveWithFilesCommand}"
                                  CommandParameter="{Binding SelectedTorrent.InfoHash}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <!-- Name -->
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        MinWidth="200"/>

                    <!-- Size -->
                    <DataGridTextColumn Header="Size"
                                        Binding="{Binding TotalWanted, StringFormat='{}{0:N0}'}"
                                        Width="90"/>

                    <!-- Progress -->
                    <DataGridTemplateColumn Header="Progress" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <ProgressBar Style="{StaticResource TorrentProgressBar}"
                                                 Value="{Binding Progress, Mode=OneWay}"
                                                 Maximum="1"
                                                 Height="18"/>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               Foreground="White">
                                        <TextBlock.Text>
                                            <Binding Path="Progress"
                                                     StringFormat="{}{0:P1}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- State -->
                    <DataGridTemplateColumn Header="State" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding State}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State}" Value="Downloading">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Seeding">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentLightBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Paused">
                                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Down Speed -->
                    <DataGridTextColumn Header="Down"
                                        Binding="{Binding DownloadRate}"
                                        Width="80"/>

                    <!-- Up Speed -->
                    <DataGridTextColumn Header="Up"
                                        Binding="{Binding UploadRate}"
                                        Width="80"/>

                    <!-- Peers -->
                    <DataGridTextColumn Header="Peers"
                                        Binding="{Binding NumPeers}"
                                        Width="55"/>

                    <!-- Seeds -->
                    <DataGridTextColumn Header="Seeds"
                                        Binding="{Binding NumSeeds}"
                                        Width="55"/>

                    <!-- Ratio -->
                    <DataGridTextColumn Header="Ratio"
                                        Binding="{Binding Ratio, StringFormat='{}{0:F2}'}"
                                        Width="60"/>

                    <!-- ETA -->
                    <DataGridTextColumn Header="ETA"
                                        Binding="{Binding EtaSeconds}"
                                        Width="70"/>

                    <!-- Category -->
                    <DataGridTextColumn Header="Category"
                                        Binding="{Binding Category}"
                                        Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DataTemplate>

</ResourceDictionary>
